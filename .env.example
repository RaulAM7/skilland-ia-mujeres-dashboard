# Optional cache - phase 2
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional dashboard auth
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASSWORD=

# Never use VITE_CRM_API_KEY.
# CRM credentials are server-side only.
