# Dashboard
DASHBOARD_ENV=local
DASHBOARD_DATA_MODE=mock
DASHBOARD_REFRESH_SECRET=
CRON_SECRET=

# CRM / Twenty - server-side only
CRM_BASE_URL=
CRM_API_KEY=
CRM_WORKSPACE_ID=
